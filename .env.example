# -----------------------------------------------------------------------------
# AgriScan Pro - Base Server Configuration
# -----------------------------------------------------------------------------
DEBUG=False
SECRET_KEY=generate_a_random_secret_key_here_at_least_50_chars
ALLOWED_HOSTS=localhost,127.0.0.1,api.agriscan.com

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Set DB_ENGINE=postgresql for production, default is sqlite
DB_ENGINE=postgresql
DB_NAME=agriscan_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# -----------------------------------------------------------------------------
# Async tasks, cache, and message broker config
# -----------------------------------------------------------------------------
# ASYNC_TASKS_ENABLED=False (default): no Redis or Celery worker required.
#   Cache uses LocMemCache; background tasks run synchronously / inline.
# ASYNC_TASKS_ENABLED=True: requires Redis (REDIS_URL) and a Celery worker.
ASYNC_TASKS_ENABLED=False
# REDIS_URL=redis://localhost:6379/0
# USE_LOCAL_MEMORY_CACHE=False
# REDIS_SSL_CERT_REQS=required  # If using ElastiCache TLS (rediss://)

# -----------------------------------------------------------------------------
# AWS S3 Storage (For uploaded CSVs / result exports)
# -----------------------------------------------------------------------------
# Leave empty if using an IAM instances profile inside AWS
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=agriscan-production-data
# AWS_S3_REGION_NAME=ap-southeast-1

# -----------------------------------------------------------------------------
# Security & Auth Settings
# -----------------------------------------------------------------------------
FORCE_SSL=True
CORS_ALLOWED_ORIGINS=https://agriscan.yourdomain.com,https://staging.agriscan.com
CORS_ALLOW_ALL=False

# Refresh cookie settings 
JWT_USE_HTTPONLY_REFRESH_COOKIE=True
JWT_REFRESH_COOKIE_SAMESITE=None
JWT_REFRESH_COOKIE_SECURE=True

# -----------------------------------------------------------------------------
# OAuth & Identity Providers
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# -----------------------------------------------------------------------------
# App URLs & Integration
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000/api
VITE_MONITOR_URL=https://agriscan-monitor.vercel.app
MONITOR_URL=https://agriscan-monitor.vercel.app

# -----------------------------------------------------------------------------
# LLM Summary
# -----------------------------------------------------------------------------
# Optional server-side provider config for production.
# Set these in backend/.env or your hosting provider secrets, not frontend/.env.
# LLM_SUMMARY_ENDPOINT=https://your-provider.example/v1/chat/completions
# LLM_SUMMARY_MODEL=your-free-tier-model
# LLM_SUMMARY_API_KEY=your-provider-api-key
# LLM_SUMMARY_TIMEOUT_SECONDS=20
# LLM_SUMMARY_MAX_OUTPUT_TOKENS=1024

# Optional NASA POWER request controls for environmental dashboard data.
# NASA_POWER_TIMEOUT_SECONDS=20
# NASA_POWER_MAX_DAYS=14
# NASA_POWER_CACHE_TTL_HOURS=24

# -----------------------------------------------------------------------------
# Access Control & Roles
# -----------------------------------------------------------------------------
# Comma-separated list of emails that should be granted Admin role upon registration
INITIAL_ADMIN_EMAILS=admin@example.com,dev@example.com
# Minimum role required to access the Monitor dashboard (admin, head_researcher, researcher, research_assistant, user, guest)
MONITOR_ACCESS_MIN_ROLE=research_assistant

# -----------------------------------------------------------------------------
# Email settings
# -----------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=hello@agriscan.com
# EMAIL_HOST_PASSWORD=app_password

# -----------------------------------------------------------------------------
# API Gateway Settings (MCP)
# -----------------------------------------------------------------------------
# GATEWAY_API_KEY=your_secure_api_key_here
