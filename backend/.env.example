# ============================================================
# AgriScan Pro - Backend Environment Variables
# ============================================================
# Local dev:
#   copy this file to .env
#
# Elastic Beanstalk:
#   Set via EB Console:
#   Configuration > Software > Environment properties
#
# Or via EB CLI:
#   eb setenv KEY=VALUE
#
# DO NOT commit real .env files or real secrets.
# ============================================================


# ────────────────────────────────────────────────────────────
# Core Django
# ────────────────────────────────────────────────────────────

# Local dev: True
# Production / Elastic Beanstalk: False
DEBUG=True

# Required.
# Use a strong random value in production, at least 50 characters.
SECRET_KEY=change-me-use-a-strong-random-secret-key-min-50-chars

# Comma-separated.
#
# Local:
#   localhost,127.0.0.1,testserver
#
# Production with current CloudFront -> EB setup:
#   agriscan-api-v2.ap-southeast-1.elasticbeanstalk.com,<frontend-cloudfront-or-custom-domain>
#
# Example:
#   agriscan-api-v2.ap-southeast-1.elasticbeanstalk.com,app.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,testserver


# ────────────────────────────────────────────────────────────
# HTTPS / Proxy / Cookie Security
# ────────────────────────────────────────────────────────────

# Current recommended production topology:
#
# Browser HTTPS
#   -> CloudFront
#      -> /        S3 frontend
#      -> /api/*   Elastic Beanstalk backend over HTTP
#      -> /health* Elastic Beanstalk backend over HTTP
#
# Because CloudFront terminates HTTPS and forwards to EB over HTTP,
# keep FORCE_SSL=False unless Django is definitely receiving and trusting
# a correct forwarded HTTPS header.
#
# Local: False
# Production with CloudFront -> EB HTTP: False
FORCE_SSL=False

# Local dev: False
# Production through HTTPS CloudFront: True
JWT_REFRESH_COOKIE_SECURE=False

# If frontend and API are same-origin through CloudFront path routing:
#   https://app.yourdomain.com
#   https://app.yourdomain.com/api/
# use Lax.
#
# If frontend and API are truly cross-site:
#   https://app.yourdomain.com
#   https://api.yourdomain.com
# use None, and JWT_REFRESH_COOKIE_SECURE must be True.
JWT_REFRESH_COOKIE_SAMESITE=Lax

# Usually leave blank.
# This lets the browser bind the cookie to the visible CloudFront/custom domain,
# not the internal Elastic Beanstalk origin domain.
JWT_REFRESH_COOKIE_DOMAIN=

# Optional depending on settings.py implementation.
# Keep enabled if settings.py reads it to configure:
# SECURE_PROXY_SSL_HEADER = ("HTTP_X_FORWARDED_PROTO", "https")
SECURE_PROXY_SSL_HEADER_ENABLED=True


# ────────────────────────────────────────────────────────────
# Database - PostgreSQL
# ────────────────────────────────────────────────────────────

# Local dev can use local PostgreSQL.
# Production uses AWS RDS PostgreSQL.
DB_ENGINE=postgresql

# Local example:
DB_NAME=agriscan_db
DB_USER=sinu
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Production example:
# DB_NAME=agriscan
# DB_USER=<rds-user>
# DB_PASSWORD=<rds-password>
# DB_HOST=<rds-endpoint>.ap-southeast-1.rds.amazonaws.com
# DB_PORT=5432


# ────────────────────────────────────────────────────────────
# Redis - Local / ElastiCache / Remote Redis
# ────────────────────────────────────────────────────────────

# Local Redis:
REDIS_URL=redis://localhost:6379/0

# Production ElastiCache with TLS:
# REDIS_URL=rediss://<elasticache-endpoint>:6379/0
#
# If Redis auth token is enabled:
# REDIS_URL=rediss://:<auth-token>@<elasticache-endpoint>:6379/0

# Local redis:// usually uses none.
# Production rediss:// should use required.
REDIS_SSL_CERT_REQS=none


# ────────────────────────────────────────────────────────────
# Gunicorn
# ────────────────────────────────────────────────────────────

# Rule of thumb: 2 x vCPU + 1.
# t3.small has 2 vCPU, so 3 is acceptable.
WEB_WORKERS=3


# ────────────────────────────────────────────────────────────
# AWS S3 Storage
# ────────────────────────────────────────────────────────────

# Production recommendation:
# Do NOT set AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY on Elastic Beanstalk.
# Use the EB EC2 Instance Profile / IAM Role instead.

AWS_STORAGE_BUCKET_NAME=agriscanpro-data-prod-293415643793-ap-southeast-1-an
AWS_S3_REGION_NAME=ap-southeast-1

# Local dev only, if not using AWS profile/SSO:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# ────────────────────────────────────────────────────────────
# CORS / CSRF
# ────────────────────────────────────────────────────────────

# Local frontend:
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production example:
# If frontend calls same-origin /api through CloudFront:
# CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
#
# If using a CloudFront domain:
# CORS_ALLOWED_ORIGINS=https://dxxxxx.cloudfront.net

CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production example:
# CSRF_TRUSTED_ORIGINS=https://app.yourdomain.com


# ────────────────────────────────────────────────────────────
# Email - SMTP / Console
# ────────────────────────────────────────────────────────────

# Local dev can use console email backend.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production SMTP example:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=<smtp-user>
# EMAIL_HOST_PASSWORD=<smtp-app-password>
# DEFAULT_FROM_EMAIL=AgriScan Pro <no-reply@yourdomain.com>

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=AgriScan Pro <no-reply@localhost>


# ────────────────────────────────────────────────────────────
# Admin Bootstrap / Initial Admins
# ────────────────────────────────────────────────────────────

# Used by createsuperuser automation or bootstrap scripts.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password
DJANGO_SUPERUSER_EMAIL=admin@localhost

# Comma-separated emails that should automatically receive admin role
# on registration / OAuth sign-in.
INITIAL_ADMIN_EMAILS=


# ────────────────────────────────────────────────────────────
# Google OAuth
# ────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ────────────────────────────────────────────────────────────
# Monitor Integration
# ────────────────────────────────────────────────────────────

# Role required to access monitor links/features.
# Example: user, research_assistant, researcher, head_researcher, admin
MONITOR_ACCESS_MIN_ROLE=researcher

# AgriScan Monitor / Vercel KV sync.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Public monitor URL if backend generates monitor links.
VITE_MONITOR_URL=
