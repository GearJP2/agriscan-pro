# ============================================================
# AgriScan Pro - Backend Environment Variables
# Copy to .env for local dev. On Elastic Beanstalk, set via:
#   eb setenv KEY=VALUE   OR   EB Console > Configuration > Environment properties
# DO NOT commit .env to Git
# ============================================================

DEBUG=False
SECRET_KEY=your-secret-key-here-min-50-chars

# ── Allowed Hosts ─────────────────────────────────────────
# Comma-separated. Add your EB environment URL and any custom domain.
# e.g. myapp.ap-southeast-1.elasticbeanstalk.com,api.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (AWS RDS PostgreSQL) ─────────────────────────
# Your friend will provide these once RDS is provisioned.
DB_ENGINE=postgresql
DB_NAME=agriscan_db
DB_USER=agriscan_user
DB_PASSWORD=your-rds-password
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432

# ── Redis (AWS ElastiCache) ───────────────────────────────
# Use rediss:// (double s) for TLS-enabled ElastiCache clusters.
# Your friend will provide the endpoint once ElastiCache is provisioned.
# Format: rediss://:auth_token@cluster-endpoint:6379/0
REDIS_URL=rediss://your-elasticache-endpoint.cache.amazonaws.com:6379/0

# TLS cert validation: 'required' for AWS-signed certs (default).
# Set to 'none' only if using self-signed certs in dev/testing.
REDIS_SSL_CERT_REQS=required

# ── Gunicorn ──────────────────────────────────────────────
# Number of gunicorn worker processes (2 × vCPUs + 1 is a good rule)
WEB_WORKERS=3

# ── AWS S3 (already in use) ───────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=ap-southeast-1

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# e.g. https://agriscan-pro.pages.dev,https://agriscan.yourdomain.com
CORS_ALLOWED_ORIGINS=

# ── Admin user (used by createsuperuser automation only) ──
Username=admin
Password=your_admin_password
Email=admin@yourdomain.com
