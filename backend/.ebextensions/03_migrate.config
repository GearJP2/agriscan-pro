container_commands:
  01_migrate:
    command: |
      /opt/elasticbeanstalk/bin/get-config environment | jq -r 'to_entries | .[] | "export \(.key)=\"\(.value)\""' > /tmp/env_vars
      source /tmp/env_vars
      source /var/app/venv/*/bin/activate
      python manage.py migrate --noinput
    leader_only: true
