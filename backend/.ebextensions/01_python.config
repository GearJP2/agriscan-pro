option_settings:
  # Tell EB which WSGI application to serve
  aws:elasticbeanstalk:container:python:
    WSGIPath: core.wsgi:application

  # Default environment variables (override in EB console / eb setenv)
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: core.settings
    DB_ENGINE: postgresql

  # Serve collected static files directly via nginx
  # nginx maps /static/ → <app_root>/staticfiles/
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: staticfiles

  # Health check — EB pings this path; our /health/ returns 200 JSON
  aws:elasticbeanstalk:environment:
    HealthCheckSuccessThreshold: Ok
  aws:elasticbeanstalk:healthreporting:system:
    SystemType: enhanced

packages:
  yum:
    # PostgreSQL client libraries required by psycopg2-binary
    postgresql-devel: []
    libpq-devel: []

container_commands:
  # collectstatic + migrate run on the leader instance only before traffic switches
  01_collectstatic:
    command: |
      source $(ls -d /var/app/venv/*/bin/activate | head -1)
      python manage.py collectstatic --noinput
    leader_only: true

  02_migrate:
    command: |
      source $(ls -d /var/app/venv/*/bin/activate | head -1)
      python manage.py migrate --noinput
    leader_only: true
