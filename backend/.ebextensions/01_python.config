option_settings:
  # Tell EB which WSGI application to serve
  aws:elasticbeanstalk:container:python:
    WSGIPath: core.wsgi:application

  # Default environment variables (override in EB console / eb setenv)
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: core.settings
    DB_ENGINE: postgresql

  # Serve collected static files directly via nginx
  # nginx maps /static/ → <app_root>/staticfiles/
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: staticfiles

  # Health check — EB pings /health/; our /health/ returns 200 JSON

  aws:elasticbeanstalk:healthreporting:system:
    SystemType: enhanced
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health/
    MatcherHTTPCode: 200

packages:
  yum:

    libpq-devel: []

container_commands:
  01_collectstatic:
    command: |
      set -xe
      EB_VENV=$(ls -d /var/app/venv/*/bin/activate | head -1)
      source $EB_VENV
      python manage.py collectstatic --noinput
    leader_only: true

  02_migrate:
    command: |
      set -xe
      EB_VENV=$(ls -d /var/app/venv/*/bin/activate | head -1)
      source $EB_VENV
      python manage.py migrate --noinput 2>&1 | tee -a /var/log/web.stdout.log; exit ${PIPESTATUS[0]}
    leader_only: true
